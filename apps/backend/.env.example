# Copy to .env and adjust. All values are optional; sane defaults are used.

# Address the HTTP server binds to.
MISU_BIND=127.0.0.1:8080

# SQLite database file.
MISU_DB=misu.sqlite

# Directory holding the web admin HTML pages (/meetings, /users, editor).
MISU_WEB_DIR=web

# Directory holding static assets (logos, QR codes, print images).
MISU_STATIC_DIR=static

# DEV auth mode. Explicit opt-in (1/true/yes/on). When on, /api/auth/wechat treats
# the login `code` as a stable fake openid so you can test without WeChat, and the
# fallback admin/admin web user is seeded. NEVER enable in production.
MISU_DEV_MODE=

# WeChat mini program credentials. When BOTH are set, /api/auth/wechat calls
# WeChat's jscode2session. In DEV mode the login `code` is treated as a stable
# fake openid so you can test without WeChat.
WECHAT_APPID=
WECHAT_SECRET=

# Bootstrap web admin (username/password) for the /login surface. When set, a
# web admin user is created on startup. In DEV mode, defaults to
# admin/admin if these are unset.
MISU_WEB_ADMIN_USER=
MISU_WEB_ADMIN_PASSWORD=

RUST_LOG=info,misu_backend=debug
