# Copy to .env and adjust. All values are optional; sane defaults are used.

# Address the HTTP server binds to.
MISU_BIND=127.0.0.1:8080

# SQLite database file.
MISU_DB=misu.sqlite

# WeChat mini program credentials. When BOTH are set, /api/auth/wechat calls
# WeChat's jscode2session. When empty, the server runs in DEV mode and treats
# the login `code` as a stable fake openid so you can test without WeChat.
WECHAT_APPID=
WECHAT_SECRET=

# On first launch, the user resolved from this WeChat openid is granted
# `site_admin` (bootstrap). In DEV mode the openid is "dev-<code>".
MISU_SEED_ADMIN_OPENID=

RUST_LOG=info,misu_backend=debug
