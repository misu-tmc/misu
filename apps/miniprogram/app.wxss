/* Global styles — mobile first, simple and uncluttered. */
page {
  background: #f5f5f7;
  color: #1c1c1e;
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", Helvetica, Arial, sans-serif;
  font-size: 30rpx;
}

.container {
  padding: 24rpx;
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #6b6b70;
  margin: 8rpx 0 16rpx 8rpx;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

.muted {
  color: #8a8a8f;
}

.btn {
  display: inline-block;
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  line-height: 1.4;
  background: #5b2a86;
  color: #ffffff;
}

.btn-outline {
  background: #ffffff;
  color: #5b2a86;
  border: 2rpx solid #5b2a86;
}

.btn-ghost {
  background: #f0ecf6;
  color: #5b2a86;
}

.btn[disabled] {
  opacity: 0.5;
}

.empty {
  text-align: center;
  color: #8a8a8f;
  padding: 80rpx 0;
}
