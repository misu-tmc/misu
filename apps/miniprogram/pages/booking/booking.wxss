.booking-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #f0f0f2;
}
.booking-row:last-child { border-bottom: none; }
.booking-info { display: flex; flex-direction: column; }
.booking-title { font-size: 30rpx; font-weight: 500; }
.booking-date { font-size: 24rpx; margin-top: 4rpx; }
.booking-actions { display: flex; align-items: center; }
.cancel-x {
  margin-left: 20rpx;
  width: 56rpx;
  height: 56rpx;
  line-height: 52rpx;
  text-align: center;
  border-radius: 50%;
  color: #b00020;
  background: #fbeaec;
  font-size: 36rpx;
}

.card-header { display: flex; align-items: center; margin-bottom: 12rpx; }
.fold-toggle {
  flex: 0 0 auto;
  width: 52rpx;
  height: 52rpx;
  line-height: 48rpx;
  margin-right: 16rpx;
  border-radius: 50%;
  text-align: center;
  background: #f0ecf6;
  color: #5b2a86;
  font-size: 36rpx;
  font-weight: 600;
}
.card-title { display: flex; flex-direction: column; min-width: 0; }
.card-number { font-size: 32rpx; font-weight: 600; }
.card-theme { font-size: 26rpx; margin-top: 4rpx; }

.role-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 0;
  border-top: 1rpx solid #f0f0f2;
}
.role-label { color: #3a3a3c; }
.role-taker { color: #6b6b70; }
.role-taker.mine { color: #5b2a86; font-weight: 600; }

/* Shrink the Take! button so a bookable row matches the height of a taken (text) row. */
.role-row .btn { padding-top: 4rpx; padding-bottom: 4rpx; }
