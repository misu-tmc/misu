<view class="container">

  <view wx:if="{{loading}}" class="empty">Loading…</view>

  <block wx:elif="{{header}}">
    <!-- Header + publish toggle -->
    <view class="head-card">
      <view class="head-top">
        <view class="head-main">
          <text class="head-title">#{{header.number}} {{header.title}}</text>
          <text class="head-sub muted">{{header.theme || 'No theme'}} · {{header.dateLabel}} {{header.timeLabel}}</text>
        </view>
        <text class="status-pill status-{{header.status}}">{{header.status}}</text>
        <view class="btn {{header.published ? 'btn-outline' : ''}} {{saving ? 'disabled' : ''}}" bindtap="togglePublish">
          {{header.published ? 'Unpublish' : 'Publish'}}
        </view>
      </view>
    </view>

    <!-- Tab strip -->
    <view class="tabwrap">
      <view class="edge left {{edgeLeft ? '' : 'hidden'}}">‹</view>
      <scroll-view class="tabs" scroll-x="true" bindscroll="onTabsScroll" enhanced="true" show-scrollbar="{{false}}">
        <view class="tab {{activeTab === item.id ? 'active' : ''}}" wx:for="{{tabs}}" wx:key="id" data-tab="{{item.id}}" bindtap="switchTab">{{item.label}}</view>
      </scroll-view>
      <view class="edge right {{edgeRight ? '' : 'hidden'}}">›</view>
    </view>

    <!-- Body -->
    <view class="body">

      <!-- Information -->
      <block wx:if="{{activeTab === 'info'}}">
        <view class="card">
          <view class="field {{highlightField === 'title' ? 'hl' : ''}}"><text class="field-label muted">Title</text><input class="field-input" value="{{info.title}}" data-field="title" bindinput="onInfoInput" /></view>
          <view class="field {{highlightField === 'theme' ? 'hl' : ''}}"><text class="field-label muted">Theme</text><input class="field-input" value="{{info.theme}}" data-field="theme" bindinput="onInfoInput" /></view>
          <view class="field {{highlightField === 'keyword' ? 'hl' : ''}}"><text class="field-label muted">Keyword</text><input class="field-input" value="{{info.keyword}}" data-field="keyword" bindinput="onInfoInput" /></view>
          <view class="field"><text class="field-label muted">Date</text><picker mode="date" value="{{info.date}}" bindchange="onDateChange"><view class="picker-value">{{info.date || 'Pick date'}}</view></picker></view>
          <view class="field-row">
            <view class="field half"><text class="field-label muted">Start</text><picker mode="time" value="{{info.start_time}}" bindchange="onStartChange"><view class="picker-value">{{info.start_time || '--:--'}}</view></picker></view>
            <view class="field half"><text class="field-label muted">End</text><picker mode="time" value="{{info.end_time}}" bindchange="onEndChange"><view class="picker-value">{{info.end_time || '--:--'}}</view></picker></view>
          </view>
          <view class="field {{highlightField === 'venue' ? 'hl' : ''}}">
            <text class="field-label muted">Venue</text>
            <picker range="{{venueNames}}" bindchange="onVenuePick"><view class="picker-value">{{info.venue || 'Pick saved venue'}}</view></picker>
            <input class="field-input sub-input" placeholder="or type venue" value="{{info.venue}}" data-field="venue" bindinput="onInfoInput" />
          </view>
        </view>
        <view class="savebar"><text class="save-hint muted">Saving Information</text><view class="btn save-btn {{saving ? 'disabled' : ''}}" bindtap="saveInfo">Save</view></view>
      </block>

      <!-- Roles -->
      <block wx:elif="{{activeTab === 'roles'}}">
        <text class="subtle muted">{{slots.length}} role slots · drag ⋮⋮ to reorder · swipe a row for Delete</text>
        <view class="drow {{swipe.type === 'role' && swipe.index === index ? 'swiped' : ''}} {{drag.type === 'role' && drag.index === index ? 'dragging' : ''}}"
              wx:for="{{slots}}" wx:key="index" wx:for-item="slot"
              style="{{drag.type === 'role' && drag.index === index ? 'transform:translateY(' + drag.offset + 'px);' : ''}}">
          <view class="handle" data-type="role" data-index="{{index}}" catchtouchstart="onDragStart" catchtouchmove="onDragMove" catchtouchend="onDragEnd">⋮⋮</view>
          <view class="drow-main" data-type="role" data-index="{{index}}" bindtouchstart="onSwipeStart" bindtouchend="onSwipeEnd">
            <view class="row-head" data-index="{{index}}" bindtap="toggleSlot">
              <text class="row-name">{{slot.role_name || slot.display || 'New role'}}</text>
              <text class="row-sub muted">Assignee: {{slot.booker_name || '—'}}</text>
            </view>
            <view wx:if="{{slot.open}}" class="row-body" catchtap="noop">
              <view class="field">
                <text class="field-label muted">Role</text>
                <picker range="{{roleNames}}" data-index="{{index}}" bindchange="onSlotRolePick"><view class="picker-value">{{slot.role_name || 'Pick role'}}</view></picker>
                <input class="field-input sub-input" placeholder="or type a new role" value="{{slot.role_name}}" data-index="{{index}}" bindinput="onSlotRoleInput" />
              </view>
              <view class="field">
                <text class="field-label muted">Custom label (optional)</text>
                <input class="field-input" value="{{slot.label}}" data-index="{{index}}" bindinput="onSlotLabelInput" />
              </view>
              <view class="field">
                <text class="field-label muted">Assignee</text>
                <picker range="{{userNames}}" data-index="{{index}}" bindchange="onSlotBookerPick"><view class="picker-value">{{slot.booker_name || 'Unassigned'}}</view></picker>
              </view>
            </view>
          </view>
          <view class="del" data-index="{{index}}" catchtap="deleteSlot">Delete</view>
        </view>
        <view class="btn btn-ghost add-btn" bindtap="addSlot">+ Add role</view>
        <view class="savebar"><text class="save-hint muted">Saving Roles</text><view class="btn save-btn {{saving ? 'disabled' : ''}}" bindtap="saveSlots">Save</view></view>
      </block>

      <!-- Sessions -->
      <block wx:elif="{{activeTab === 'sessions'}}">
        <text class="subtle muted">Start times auto-computed · drag ⋮⋮ to reorder · swipe a row for Delete</text>
        <view class="drow {{swipe.type === 'session' && swipe.index === index ? 'swiped' : ''}} {{drag.type === 'session' && drag.index === index ? 'dragging' : ''}}"
              wx:for="{{sessions}}" wx:key="index" wx:for-item="ses"
              style="{{drag.type === 'session' && drag.index === index ? 'transform:translateY(' + drag.offset + 'px);' : ''}}">
          <view class="handle" data-type="session" data-index="{{index}}" catchtouchstart="onDragStart" catchtouchmove="onDragMove" catchtouchend="onDragEnd">⋮⋮</view>
          <view class="drow-main" data-type="session" data-index="{{index}}" bindtouchstart="onSwipeStart" bindtouchend="onSwipeEnd">
            <view class="row-head" data-index="{{index}}" bindtap="toggleSession">
              <text class="row-name"><text class="ses-time">{{ses.start}}</text> {{ses.name}}</text>
              <text class="row-sub muted">{{ses.duration_minutes}}' · {{ses.roleLabel || '—'}}</text>
            </view>
            <view wx:if="{{ses.open}}" class="row-body" catchtap="noop">
              <view class="field">
                <text class="field-label muted">Session name</text>
                <input class="field-input" value="{{ses.name}}" data-index="{{index}}" data-field="name" bindinput="onSessionInput" />
              </view>
              <view class="field">
                <text class="field-label muted">Group</text>
                <input class="field-input" value="{{ses.group_label}}" data-index="{{index}}" data-field="group_label" bindinput="onSessionInput" />
              </view>
              <view class="field">
                <text class="field-label muted">Duration (min)</text>
                <input class="field-input" type="number" value="{{ses.duration_minutes}}" data-index="{{index}}" data-field="duration_minutes" bindinput="onSessionInput" />
              </view>
              <view class="field">
                <text class="field-label muted">Role</text>
                <picker range="{{slotPickerLabels}}" data-index="{{index}}" bindchange="onSessionRolePick"><view class="picker-value">{{ses.roleLabel || 'No role'}}</view></picker>
              </view>
            </view>
          </view>
          <view class="del" data-index="{{index}}" catchtap="deleteSession">Delete</view>
        </view>
        <view class="btn btn-ghost add-btn" bindtap="addSession">+ Add session</view>
        <view class="savebar"><text class="save-hint muted">Saving Sessions</text><view class="btn save-btn {{saving ? 'disabled' : ''}}" bindtap="saveSessions">Save</view></view>
      </block>

      <!-- Speeches -->
      <block wx:elif="{{activeTab === 'speeches'}}">
        <view wx:if="{{speeches.length === 0}}" class="card empty-tab">
          <text class="et-title">Prepared Speeches</text>
          <text class="muted">No prepared speech slots yet. Add Speaker or Prepared Speech roles first.</text>
        </view>
        <view
          wx:for="{{speeches}}"
          wx:key="role_slot_id"
          wx:for-item="speech"
          class="card speech-card {{highlightSlotId === speech.role_slot_id ? 'hl-card' : ''}}"
        >
          <view class="speech-head">
            <text class="et-title">{{speech.display}}</text>
            <text class="muted">{{speech.booker_name || 'Unassigned'}}</text>
          </view>
          <view class="field"><text class="field-label muted">Title</text><input class="field-input" value="{{speech.title}}" data-index="{{index}}" data-field="title" bindinput="onSpeechInput" /></view>
          <view class="field"><text class="field-label muted">Pathway</text><input class="field-input" value="{{speech.pathway}}" data-index="{{index}}" data-field="pathway" bindinput="onSpeechInput" /></view>
          <view class="field"><text class="field-label muted">Level</text><input class="field-input" type="number" value="{{speech.level}}" data-index="{{index}}" data-field="level" bindinput="onSpeechInput" /></view>
          <view class="field"><text class="field-label muted">Purpose</text><textarea class="field-input textarea speech-textarea" auto-height="{{true}}" value="{{speech.purpose}}" data-index="{{index}}" data-field="purpose" maxlength="240" bindinput="onSpeechInput" /></view>
          <view class="field"><text class="field-label muted">Description</text><textarea class="field-input textarea speech-textarea" auto-height="{{true}}" value="{{speech.description}}" data-index="{{index}}" data-field="description" maxlength="240" bindinput="onSpeechInput" /></view>
        </view>
        <view class="savebar"><text class="save-hint muted">Saving Speeches</text><view class="btn save-btn {{saving ? 'disabled' : ''}}" bindtap="saveSpeeches">Save</view></view>
      </block>

    </view>
  </block>

  <view wx:else class="empty">No meeting to edit.</view>

</view>
