/* Meeting editor — tabbed sections with unified draggable rows. */

.head-card { padding: 20rpx 28rpx; }
.head-top {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.head-main { flex: 1; min-width: 0; }
.head-title { display: block; font-size: 32rpx; font-weight: 600; }
.head-sub { display: block; margin-top: 6rpx; font-size: 24rpx; }
.status-pill {
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  background: #f0ecf6;
  color: #5b2a86;
  text-transform: capitalize;
}
.status-published { background: #e4f5e9; color: #1f8f4a; }
.status-draft { background: #f0ecf6; color: #6b6b70; }

/* Tab strip */
.tabwrap { position: relative; background: #fff; border-bottom: 1rpx solid #ececee; }
.tabs { white-space: nowrap; }
.tab {
  display: inline-block;
  padding: 22rpx 22rpx 18rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #8a8a8f;
  border-bottom: 5rpx solid transparent;
}
.tab.active { color: #5b2a86; border-bottom-color: #5b2a86; }
.edge {
  position: absolute; top: 0; bottom: 0; width: 44rpx;
  display: flex; align-items: center; justify-content: center;
  color: #5b2a86; font-weight: 800; font-size: 34rpx; z-index: 2;
}
.edge.left { left: 0; background: linear-gradient(90deg, #fff 55%, rgba(255,255,255,0)); }
.edge.right { right: 0; background: linear-gradient(270deg, #fff 55%, rgba(255,255,255,0)); }
.edge.hidden { display: none; }

/* Body */
.body { padding: 24rpx 24rpx 140rpx; }
.card { background: #fff; border-radius: 20rpx; padding: 24rpx; }
.subtle { display: block; font-size: 24rpx; margin: 0 8rpx 16rpx; }

/* Fields */
.field { margin-top: 24rpx; }
.field:first-child { margin-top: 0; }
.field-row { display: flex; gap: 24rpx; }
.field-row .half { flex: 1; }
.field-label { display: block; font-size: 24rpx; margin-bottom: 8rpx; }
.field-input {
  font-size: 30rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #ececee;
}
.picker-value {
  margin-top: 4rpx;
  padding: 12rpx 0;
  font-size: 30rpx;
  border-bottom: 1rpx solid #ececee;
  color: #1c1c1e;
}
.sub-input { margin-top: 12rpx; font-size: 28rpx; }
/* Highlighted field from a Prepare deep-link */
.field.hl .field-input, .field.hl .picker-value { border-bottom-color: #5b2a86; box-shadow: 0 2rpx 0 0 #5b2a86; }
.field.hl .field-label { color: #5b2a86; }

/* Unified draggable row (Roles & Sessions share this) */
.drow {
  position: relative;
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  background: #fff;
  border: 1rpx solid #f0f0f2;
  border-radius: 16rpx;
  padding: 18rpx 20rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
}
.drow.dragging { z-index: 5; box-shadow: 0 8rpx 24rpx rgba(0,0,0,.15); opacity: .96; }
.handle { color: #b9b9c0; font-size: 34rpx; line-height: 1; letter-spacing: -6rpx; padding-top: 6rpx; flex: 0 0 auto; }
.drow-main { flex: 1; min-width: 0; transition: opacity .18s; }
.row-head { display: flex; flex-direction: column; }
.row-name { font-size: 28rpx; font-weight: 500; }
.row-sub { font-size: 24rpx; margin-top: 4rpx; }
.ses-time { color: #5b2a86; font-weight: 700; font-variant-numeric: tabular-nums; }
.row-body { padding-top: 12rpx; }

/* Swipe reveal: content fades in place, Delete appears (content does not translate) */
.del {
  position: absolute; right: 20rpx; top: 50%; transform: translateY(-50%);
  background: #fdecec; color: #c62828; font-weight: 700; font-size: 26rpx;
  padding: 14rpx 26rpx; border-radius: 12rpx; opacity: 0; pointer-events: none; transition: opacity .18s;
}
.drow.swiped .drow-main { opacity: .3; }
.drow.swiped .del { opacity: 1; pointer-events: auto; }

/* Buttons */
.add-btn { display: block; text-align: center; margin-top: 8rpx; padding: 18rpx; }

/* Fixed per-section save bar */
.savebar {
  position: fixed; left: 0; right: 0; bottom: 0;
  display: flex; align-items: center; gap: 16rpx;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: #fff; border-top: 1rpx solid #ececee;
}
.save-hint { flex: 1; font-size: 24rpx; }
.save-btn { padding: 20rpx 44rpx; }
.save-btn.disabled { opacity: 0.5; }

/* Empty / stub tabs */
.empty-tab { display: flex; flex-direction: column; gap: 12rpx; }
.et-title { font-size: 30rpx; font-weight: 600; }
.speech-card { margin-bottom: 20rpx; }
.speech-card.hl-card { border: 2rpx solid #5b2a86; box-shadow: 0 0 0 4rpx #f0ecf6; }
.speech-head { display: flex; align-items: baseline; justify-content: space-between; gap: 16rpx; }
.textarea { min-height: 150rpx; line-height: 1.5; }
.speech-textarea { min-height: 48rpx; }
