<view class="container">

  <view wx:if="{{loading}}" class="empty">Loading…</view>

  <block wx:elif="{{hasMeeting}}">
    <!-- Title card -->
    <view class="card title-card">
      <view class="title-head">
        <text class="title-line">#{{meeting.number}} · {{meeting.dateLabel}} · {{meeting.timeLabel}}</text>
        <text class="status-badge status-{{meeting.phase}}">{{meeting.phase}}</text>
      </view>
      <text class="title-sub">{{meeting.theme}} · {{meeting.venue}}</text>
      <view class="actions">
        <view class="btn {{checkedIn ? 'btn-checked' : 'btn-outline'}}" bindtap="goCheckIn">{{checkedIn ? 'Checked in' : 'Check in'}}</view>
        <view class="btn btn-outline" bindtap="comingSoon">Vote for best</view>
        <view class="btn {{timerMode ? 'btn-timer-on' : 'btn-outline'}}" bindtap="toggleTimerMode">{{timerMode ? 'Timer on' : 'Timer mode'}}</view>
      </view>
    </view>

    <!-- Agenda -->
    <view class="section-title">Agenda</view>
    <view class="card">
      <view class="agenda-row {{item.running ? 'running' : ''}}" wx:for="{{agenda}}" wx:key="key">
        <text class="agenda-time">{{item.start}}</text>
        <view class="agenda-main">
          <text class="agenda-name">{{item.name}}</text>
          <text class="agenda-meta muted">{{item.duration_minutes}}' · {{item.taker || '—'}}</text>
          <text wx:if="{{timerMode}}" class="agenda-meta timer-elapsed">Elapsed {{item.elapsedText}}</text>
        </view>
        <view wx:if="{{timerMode}}" class="timer-actions">
          <view wx:if="{{item.running}}" class="timer-btn restart" data-key="{{item.key}}" bindtap="restartTimer">↺</view>
          <view class="timer-btn" data-key="{{item.key}}" bindtap="playTimer">{{item.running ? 'Ⅱ' : '▶'}}</view>
          <view wx:if="{{!item.isSub}}" class="timer-btn add" data-key="{{item.key}}" bindtap="addSubSession">+</view>
        </view>
      </view>
    </view>
  </block>

  <view wx:else class="empty">No upcoming meeting yet.</view>

</view>
