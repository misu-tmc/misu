.title-card { display: flex; flex-direction: column; }
.title-head { display: flex; align-items: center; justify-content: space-between; gap: 12rpx; }
.title-line { font-size: 32rpx; font-weight: 600; }
.status-badge { font-size: 22rpx; padding: 4rpx 16rpx; border-radius: 999rpx; text-transform: capitalize; white-space: nowrap; }
.status-badge.status-draft { background: #fff3e0; color: #b26a00; }
.status-badge.status-open { background: #e8f5e9; color: #2e7d32; }
.status-badge.status-ongoing { background: #e3f2fd; color: #1565c0; }
.status-badge.status-archived { background: #eceff1; color: #546e7a; }
.title-sub { color: #6b6b70; font-size: 26rpx; margin-top: 6rpx; }
.actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 24rpx;
}
.btn-checked {
  background: #2e7d32;
  color: #fff;
}
.btn-timer-on {
  background: #1565c0;
  color: #fff;
}

.agenda-row {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 0;
  border-top: 1rpx solid #f0f0f2;
}
.agenda-row:first-child { border-top: none; }
.agenda-row.running { background: #f4f9ff; margin: 0 -12rpx; padding-left: 12rpx; padding-right: 12rpx; border-radius: 12rpx; }
.agenda-row.sub-row { padding-left: 48rpx; }
.agenda-time {
  width: 110rpx;
  color: #5b2a86;
  font-weight: 600;
  font-variant-numeric: tabular-nums;
}
.agenda-main { display: flex; flex-direction: column; flex: 1; }
.agenda-name { font-size: 30rpx; }
.agenda-meta { font-size: 24rpx; margin-top: 4rpx; }
.timer-actions { display: flex; align-items: center; gap: 10rpx; margin-left: 12rpx; }
.timer-btn {
  width: 52rpx;
  height: 52rpx;
  line-height: 48rpx;
  text-align: center;
  border-radius: 50%;
  background: #f0ecf6;
  color: #5b2a86;
  font-size: 26rpx;
  font-weight: 700;
}
.timer-btn.stop { background: #fbeaec; color: #b00020; }
.timer-btn.add { background: #e8f5e9; color: #2e7d32; }
