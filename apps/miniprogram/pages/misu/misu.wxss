.hero { display: flex; flex-direction: column; align-items: center; padding: 48rpx 28rpx; }
.logo {
  width: 140rpx;
  height: 140rpx;
  border-radius: 32rpx;
  background: #5b2a86;
  color: #fff;
  font-size: 44rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  letter-spacing: 2rpx;
}
.club-name { font-size: 34rpx; font-weight: 600; margin-top: 24rpx; text-align: center; }
.motto { color: #8a8a8f; margin-top: 8rpx; }
.body { display: block; line-height: 1.6; }
.body.muted { margin-top: 6rpx; }
